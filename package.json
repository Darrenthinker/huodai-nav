{
  "name": "huodai-nav",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "npx --yes kill-port 3018 && next dev -p 3018",
    "dev:clean": "npx --yes kill-port 3018 && node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && next dev -p 3018",
    "build": "next build && node scripts/inject-sogou-meta.mjs && node scripts/generate-sitemap.mjs",
    "start": "next start -p 3018",
    "preview": "npx --yes serve out -l 3018",
    "lint": "next lint",
    "kill-ports": "npx --yes kill-port 3018",
    "rebuild": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && npm run build",
    "fetch-logos": "node scripts/fetch-all-logos.mjs",
    "fetch-logos:new": "node scripts/fetch-all-logos.mjs --min-id 2837",
    "fetch-logos:sea": "node scripts/fetch-all-logos.mjs --min-id 3016",
    "fetch-logos:sea-new": "node scripts/fetch-all-logos.mjs --min-id 3074"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5.7",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
